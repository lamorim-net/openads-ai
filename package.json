{
  "name": "openads-ai",
  "version": "0.1.0",
  "description": "Open-source AI command center for digital marketers. Audit campaigns, write ad copy, and build strategies — from your terminal.",
  "main": "dist/cli.js",
  "bin": {
    "openads": "dist/cli.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "skills/",
    "templates/",
    "scripts/",
    "logo.txt",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lamorim-net/openads-ai.git"
  },
  "homepage": "https://github.com/lamorim-net/openads-ai",
  "bugs": {
    "url": "https://github.com/lamorim-net/openads-ai/issues"
  },
  "author": "Luiz Amorim",
  "license": "MIT",
  "keywords": [
    "marketing",
    "google-ads",
    "meta-ads",
    "facebook-ads",
    "ai",
    "advertising",
    "copywriting",
    "cro",
    "cli",
    "openads"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "piConfig": {
    "configDir": ".openads",
    "mcps": {
      "google-ads": {
        "command": "uvx",
        "args": [
          "adloop"
        ]
      },
      "meta-ads": {
        "url": "https://mcp.facebook.com/ads/sse"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "enquirer": "^2.4.1",
    "gradient-string": "^3.0.0",
    "open": "^11.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
